# Gurney environment variables.
# Copy to .env and fill in. All values shown are defaults unless noted.

# --- Telegram ---------------------------------------------------------------
# Bot token from @BotFather. Required.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the bot. Required.
# Example: 123456789,987654321
TELEGRAM_ALLOWED_IDS=

# --- Ollama -----------------------------------------------------------------
# HTTP endpoint of the Ollama server. Inside docker-compose this is
# http://ollama:11434; on bare metal http://localhost:11434.
OLLAMA_URL=http://localhost:11434

# Number of CPU threads Ollama may use. Tune to physical cores.
# Pi 4/5: 4. Mini PC: 4-8. 5800H: 8.
OLLAMA_NUM_THREADS=4

# Enable Ollama flash attention (no quality loss, measurable speedup on qwen3).
OLLAMA_FLASH_ATTENTION=1

# --- Gurney core ------------------------------------------------------------
# Config / data dir. Defaults to ~/.gurney when unset.
GURNEY_HOME=

# Default chat profile. Pi-class: qwen3.5:0.5b. Standard/Heavy: qwen3.5:0.8b.
GURNEY_CHAT_MODEL=qwen3.5:0.8b

# Reasoning profile. Leave blank on small devices.
GURNEY_REASON_MODEL=

# Tool-use profile. Optional — when set, the orchestrator routes any chat
# call that has tool schemas attached through this model instead of
# GURNEY_CHAT_MODEL. Useful when the chat model is small/fast and a separate
# model is better at picking the right tool and shaping its arguments.
GURNEY_TOOLS_MODEL=

# Log level: debug | info | warn | error.
GURNEY_LOG_LEVEL=info

# Hardware tier override: small | standard | heavy.
# Leave blank to let `gurney init` detect from RAM/CPU.
GURNEY_TIER=

# --- Resilience tunables (optional) -----------------------------------------
# Idle threshold after which a heavy (e.g. reason) model is unloaded from
# RAM. 0 disables the sweep. Default 600000 (10 minutes). Lower this on a
# Pi 4 where you'd rather take a cold-start hit than keep 9b resident.
GURNEY_HEAVY_IDLE_MS=

# Hard ceiling for a single LLM inference. Default 120000 (120s) — long
# enough for a 9b cold-start on CPU, short enough that a hung Ollama
# surfaces as an error instead of pinning the user queue.
GURNEY_INFERENCE_TIMEOUT_MS=

# Max chained tool-call rounds per user turn. Default 4. Raise to 5–6 for
# heavy calendar conflict resolution; lower to 2 for plain Q&A bots.
GURNEY_MAX_TOOL_ROUNDS=
