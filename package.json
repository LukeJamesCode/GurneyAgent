{
  "name": "gurney",
  "version": "1.0.0",
  "description": "Small, terminal-first AI agent. CPU-only. Extensions turn it into anything.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "gurney": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-migrations.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p extensions/gurney-everyday-assistant && tsc --noEmit -p extensions/gurney-tts && tsc --noEmit -p extensions/gurney-instant-responses",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node scripts/run-tests.mjs",
    "bench:spec-decode": "node scripts/bench-spec-decode.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "dependencies": {
    "tsx": "^4.19.2",
    "@inquirer/prompts": "^8.4.2",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "grammy": "^1.42.0"
  }
}
