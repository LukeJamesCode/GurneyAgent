{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "rootDir": "../..",
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../../src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
